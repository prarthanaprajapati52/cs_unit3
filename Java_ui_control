import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.layout.GridPane;
import javafx.stage.Stage;

public class BasicForm extends Application {

    @Override
    public void start(Stage primaryStage) {
        
        // Labels
        Label lblTitle = new Label("Student Registration Form");
        Label lblName = new Label("Name:");
        Label lblPassword = new Label("Password:");
        Label lblGender = new Label("Gender:");
        Label lblCourse = new Label("Course:");
        Label lblHobby = new Label("Hobbies:");
        Label lblAddress = new Label("Address:");

        // TextField
        TextField txtName = new TextField();

        // PasswordField
        PasswordField txtPassword = new PasswordField();

        // RadioButtons
        RadioButton rbMale = new RadioButton("Male");
        RadioButton rbFemale = new RadioButton("Female");
        ToggleGroup genderGroup = new ToggleGroup();
        rbMale.setToggleGroup(genderGroup);
        rbFemale.setToggleGroup(genderGroup);

        // ComboBox
        ComboBox<String> cmbCourse = new ComboBox<>();
        cmbCourse.getItems().addAll("BCA", "BBA", "BCom", "MCA");

        // CheckBoxes
        CheckBox cbReading = new CheckBox("Reading");
        CheckBox cbMusic = new CheckBox("Music");
        CheckBox cbSports = new CheckBox("Sports");

        // TextArea
        TextArea txtAddress = new TextArea();
        txtAddress.setPrefRowCount(3);

        // Button
        Button btnSubmit = new Button("Submit");

        // Action on button
        btnSubmit.setOnAction(e -> {
            String name = txtName.getText();
            String password = txtPassword.getText();

            String gender = "";
            if (rbMale.isSelected()) {
                gender = "Male";
            } else if (rbFemale.isSelected()) {
                gender = "Female";
            }

            String course = cmbCourse.getValue();

            String hobbies = "";
            if (cbReading.isSelected()) hobbies += "Reading ";
            if (cbMusic.isSelected()) hobbies += "Music ";
            if (cbSports.isSelected()) hobbies += "Sports ";

            String address = txtAddress.getText();

            Alert alert = new Alert(Alert.AlertType.INFORMATION);
            alert.setTitle("Form Details");
            alert.setHeaderText("Submitted Information");
            alert.setContentText(
                    "Name: " + name +
                    "\nPassword: " + password +
                    "\nGender: " + gender +
                    "\nCourse: " + course +
                    "\nHobbies: " + hobbies +
                    "\nAddress: " + address
            );
            alert.showAndWait();
        });

        // Layout
        GridPane grid = new GridPane();
        grid.setPadding(new Insets(20));
        grid.setVgap(10);
        grid.setHgap(10);

        grid.add(lblTitle, 1, 0);
        grid.add(lblName, 0, 1);
        grid.add(txtName, 1, 1);

        grid.add(lblPassword, 0, 2);
        grid.add(txtPassword, 1, 2);

        grid.add(lblGender, 0, 3);
        grid.add(rbMale, 1, 3);
        grid.add(rbFemale, 2, 3);

        grid.add(lblCourse, 0, 4);
        grid.add(cmbCourse, 1, 4);

        grid.add(lblHobby, 0, 5);
        grid.add(cbReading, 1, 5);
        grid.add(cbMusic, 2, 5);
        grid.add(cbSports, 3, 5);

        grid.add(lblAddress, 0, 6);
        grid.add(txtAddress, 1, 6);

        grid.add(btnSubmit, 1, 7);

        Scene scene = new Scene(grid, 500, 400);
        primaryStage.setTitle("JavaFX Basic Form");
        primaryStage.setScene(scene);
        primaryStage.show();
    }

    public static void main(String[] args) {
        launch(args);
    }
}
